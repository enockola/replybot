<%- include('partials/dashboard/header') %>

<!-- main -->
<main class="canned-response">
  <aside class="side-bar nav-adjust">
    <ul class="category">
      <li><a href="/responses">Canned Response</a></li>
      <li><a href="/suggestions">Response Suggestions</a></li>
      <li><a href="/support">Support</a></li>
      <li><a href="/my tickets">My Tickets</a></li>
      <li><a href="/register/list">Users</a></li>
    </ul>
    <div>
      <img
        class="logo"
        src="/images/logo-dark.png"
        width="113"
        height="113"
        alt="ReplyBot logo image"
      />
      <p>©2026. Replybot</p>
    </div>
  </aside>
  <div class="nav-adjust">
    <div class="content-container">
      <div class="content-nav">
        <a href="/dashboard" title="Dashboard Home Page">
          <i class="fa-solid fa-house"></i>
        </a>
        |
      </div>

      <h1 class="header welcome">Welcome <%= user.first_name %>!</h1>

      <div class="dashboard">
        <div class="user-info">
          <div class="user-detail">
            <span class="label">Name:</span>
            <span class="value"
              ><%= user.first_name %> <%= user.last_name %></span
            >
          </div>

          <div class="user-detail">
            <span class="label">Email:</span>
            <span class="value"><%= user.email %></span>
          </div>

          <div class="user-detail">
            <span class="label">Role:</span>
            <span class="value"><%= user.roleName %></span>
          </div>

          <div class="user-detail">
            <span class="label">Joined:</span>
            <span class="value">
              <%= new Date(user.created_at).toLocaleDateString() %>
            </span>
          </div>
        </div>

        <div class="session-debug">
          <h3>Session Information (For Learning Purposes)</h3>
          <p>
            <em
              >This section shows your current session data for educational
              purposes.</em
            >
          </p>
          <pre><%= JSON.stringify(sessionData, null, 2) %></pre>
          <p>
            <strong>
              If you see a password property in the above object you have a
              security vulnerability, fix it!
            </strong>
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/dashboard/footer') %>
