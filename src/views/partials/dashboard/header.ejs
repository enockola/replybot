<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Enoch Olayemi">
    <meta name="description"
        content="This is my final project for WDD 131 | a customer service page for canned responses.">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="icon" href="/images/favicon.png" media="all" type="image/x-icon">
    <% if (NODE_ENV.includes('dev')) { %>
    <script>
        // Get the current hostname and port from the browser
        const host = window.location.hostname;
        const currentPort = window.location.port;

        // Calculate WebSocket port (current port + 1)
        const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

        // Create WebSocket connection using dynamic hostname and port
        const ws = new WebSocket(`ws://${host}:${wsPort}`);
        ws.onclose = () => {
            setTimeout(() => location.reload(), 2000);
        };
    </script>
    <% } %>
</head>

<body>
    <!-- animated background -->
    <div class="animated-background-container">
        <div class="animated-background">
            <div class="bubble" style="top: 10%; left: 20%;"></div>
            <div class="bubble" style="top: 30%; left: 70%;"></div>
            <div class="polygon" style="top: 50%; left: 40%;"></div>
            <div class="polygon" style="top: 80%; left: 10%;"></div>
            <div class="wave" style="top: 0; left: 0;"></div>
            <div class="wave" style="top: 200px; left: 0;"></div>
            <div class="dot" style="top: 15%; left: 30%;"></div>
            <div class="dot" style="top: 60%; left: 80%;"></div>
            <div class="shape" style="top: 70%; left: 60%;"></div>
            <div class="shape" style="top: 20%; left: 50%;"></div>
        </div>
    </div>

    <!-- header -->
    <header class="container">
        <nav>
            <img class="logo" src="images/logo.png" width="113" height="113" alt="ReplyBot logo">
            <ul class="nav-list">
                <li><a href="/dashboard">Admin</a></li>
                <li><a href="/">Log Out</a></li>
            </ul>
            <div class="hamburger">
                <i class="fa-solid fa-bars"></i>
            </div>
        </nav>
    </header>