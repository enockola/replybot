<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Enoch Olayemi">
    <meta name="description" content="ReplyBot is a customer support dashboard for managing canned responses, improving efficiency, and streamlining communication.">
    <meta name="keywords" content="customer support, canned responses, help desk, support dashboard, reply automation">

    <meta property="og:title" content="ReplyBot | Customer Support Dashboard">
    <meta property="og:description" content="Manage and organize canned responses to improve customer support workflows.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://replybot-app.onrender.com/">
    <meta property="og:image" content="https://replybot-app.onrender.com/images/customer-support.jpg">
    <meta property="og:site_name" content="ReplyBot">
    <meta property="og:locale" content="en_US">
    <title><%= title %></title>
    <link rel="stylesheet" media="all" href="/css/main.css">
    <link rel="icon" href="/images/favicon.png" media="all" type="image/x-icon">
    <% if (NODE_ENV.includes('dev')) { %>
    <script>
        // Get the current hostname and port from the browser
        const host = window.location.hostname;
        const currentPort = window.location.port;

        // Calculate WebSocket port (current port + 1)
        const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

        // Create WebSocket connection using dynamic hostname and port
        const ws = new WebSocket(`ws://${host}:${wsPort}`);
        ws.onclose = () => {
            setTimeout(() => location.reload(), 2000);
        };
    </script>
    <% } %>
</head>

<body>
    <!-- animated background -->
    <div class="animated-background-container">
        <div class="animated-background">
            <div class="bubble" style="top: 10%; left: 20%;"></div>
            <div class="bubble" style="top: 30%; left: 70%;"></div>
            <div class="polygon" style="top: 50%; left: 40%;"></div>
            <div class="polygon" style="top: 80%; left: 10%;"></div>
            <div class="wave" style="top: 0; left: 0;"></div>
            <div class="wave" style="top: 200px; left: 0;"></div>
            <div class="dot" style="top: 15%; left: 30%;"></div>
            <div class="dot" style="top: 60%; left: 80%;"></div>
            <div class="shape" style="top: 70%; left: 60%;"></div>
            <div class="shape" style="top: 20%; left: 50%;"></div>
        </div>
    </div>

    <!-- header -->
    <header class="container">
        <nav>
            <img src="/images/logo.png" width="113" height="113" alt="ReplyBot logo image">
            
            <ul class="nav-list">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/resources">Resources</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/contact/replies">Contact Responses</a></li>
                <li><a href="/dashboard">Log In</a></li>
                <li><a href="/register">Register</a></li>
                
            </ul>
            <div class="hamburger">
                <i class="fa-solid fa-bars"></i>
            </div>
        </nav>
    </header>