<%- include('../../partials/header') %>

<main class="container nav-adjust">
    <h1><%= title %></h1>
    <p>
        Register for a new account by providing your information below. All fields are required and passwords must meet security requirements.
    </p>

    <% if (errorMessages && errorMessages.length > 0) { %>
        <div class="form-errors">
            <ul>
                <% errorMessages.forEach(message => { %>
                    <li><%= message %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <% if (successMessages && successMessages.length > 0) { %>
        <div class="form-success">
            <ul>
                <% successMessages.forEach(message => { %>
                    <li><%= message %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form method="POST" action="/register" class="registration-form">
        <!-- First name -->
        <div class="form-group">
            <label for="firstName">First Name</label>
            <input
                type="text"
                id="firstName"
                name="firstName"
                minlength="2"
                required
                placeholder="Enter your first name"
                value="<%= formData?.firstName || '' %>"
            >
        </div>

        <!-- Last name -->
        <div class="form-group">
            <label for="lastName">Last Name</label>
            <input
                type="text"
                id="lastName"
                name="lastName"
                minlength="2"
                required
                placeholder="Enter your last name"
                value="<%= formData?.lastName || '' %>"
            >
        </div>

        <!-- Email -->
        <div class="form-group">
            <label for="email">Email Address</label>
            <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Enter your email address"
                value="<%= formData?.email || '' %>"
            >
        </div>

        <!-- Confirm email -->
        <div class="form-group">
            <label for="emailConfirm">Confirm Email Address</label>
            <input
                type="email"
                id="emailConfirm"
                name="emailConfirm"
                required
                placeholder="Re-enter your email address"
                value="<%= formData?.emailConfirm || '' %>"
            >
        </div>

        <!-- Password -->
        <div class="form-group">
            <label for="password">Password</label>
            <input
                type="password"
                id="password"
                name="password"
                minlength="8"
                pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"
                required
                placeholder="Create a password"
            >
            <div class="help-text">
                Must be at least 8 characters with a number and special character.
            </div>
        </div>

        <!-- Confirm password -->
        <div class="form-group">
            <label for="passwordConfirm">Confirm Password</label>
            <input
                type="password"
                id="passwordConfirm"
                name="passwordConfirm"
                minlength="8"
                required
                placeholder="Re-enter your password"
            >
        </div>

        <button type="submit">Create Account</button>
    </form>
</main>

<%- include('../../partials/footer') %>