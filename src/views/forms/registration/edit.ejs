<%- include('../../partials/dashboard/header') %>

<main class="canned-response">
    <aside class="side-bar nav-adjust">
        <ul class="category">
            <li><a href="/responses">Canned Response</a></li>
            <li><a href="/suggestions">Suggestions</a></li>
            <li><a href="/tickets">Tickets</a></li>
            
            <% if (user && (user.roleName === 'admin' || user.roleName === 'vendor')) { %>
                <li><a href="/tickets/support">Support</a></li>
            <% } %>

            <% if (user && user.roleName === 'admin') { %>
                <li><a href="/suggestions/review">Review Suggestions</a></li>
            <% } %>

            <li><a href="/register/list">Users</a></li>
        </ul>

        <div>
            <img class="logo" src="/images/logo-dark.png" width="113" height="113" alt="ReplyBot logo image">
            <p>©2026. Replybot</p>
        </div>
    </aside>

    <div class="nav-adjust">
        <div class="content-container">
            <div class="content-nav">
                <a href="/dashboard" title="Dashboard Home Page"><i class="fa-solid fa-house"></i></a> |
                <a href="/register/list" title="Users">Users</a> |
                <a href="" title="<%= title %>"><%= title %></a> 
            </div>

            <h1 class="header"><%= title %></h1>

            <div class="ungrid-content">
                <form method="POST" action="/register/<%= user.id %>/edit" class="contact-form">
                    <div class="form-group">
                        <label for="firstName">First Name:</label>
                        <input
                            type="text"
                            id="firstName"
                            name="firstName"
                            value="<%= formData?.firstName || user.first_name %>"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="lastName">Last Name:</label>
                        <input
                            type="text"
                            id="lastName"
                            name="lastName"
                            value="<%= formData?.lastName || user.last_name %>"
                            required
                        >
                    </div>
                    
                    <div class="form-group">
                        <label for="email">Email:</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            value="<%= formData?.email || user.email %>"
                            required
                        >
                    </div>

                    <button type="submit">Update Account</button>
                    <a href="/register/list">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</main>

<%- include('../../partials/dashboard/footer') %>